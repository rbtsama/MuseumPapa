{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "cd coupon-map && corepack enable && pnpm install --frozen-lockfile && pnpm run build",
  "outputDirectory": "coupon-map/dist",
  "installCommand": "echo 'skip — handled inside buildCommand'",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
