# Copy this file to .env and fill in your real library card barcodes.
# .env is gitignored — never commit real barcodes.
#
# Key format: <LIBRARY_ID_UPPER>_BARCODE   (e.g. WAKEFIELD -> library_id "wakefield")
# Library IDs are defined in config/library_seeds.json.
#
# Read at runtime via GET /api/cards by:
#   - local:  scripts/serve_admin.py (parses this .env)
#   - online: api/cards.mjs on Vercel — set these as Vercel Environment Variables
#             (Settings -> Environment Variables), NOT by committing .env.
#
# ⚠ SECURITY: /api/cards returns these to anyone who can reach it. Only configure
#   them online if the admin deployment is access-protected; otherwise leave them
#   unset online and type card numbers in the panel's per-card field (localStorage).

WAKEFIELD_BARCODE=
READING_BARCODE=
WILMINGTON_BARCODE=
BPL_BARCODE=
SOMERVILLE_BARCODE=
