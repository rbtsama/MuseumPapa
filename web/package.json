{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "node sync-admin.mjs",
    "build": "tsc -b && vite build",
    "prebuild": "node sync-admin.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "copy:admin": "node sync-admin.mjs",
    "copy:assets": "node -e \"const fs=require('fs');const path=require('path');for(const [s,d] of [['../data/static/images','public/images'],['../data/static/placeholders','public/placeholders']]){if(fs.existsSync(d))fs.rmSync(d,{recursive:true,force:true});if(fs.existsSync(s)){fs.cpSync(s,d,{recursive:true});console.log(s+' -> '+d+': '+fs.readdirSync(d).length+' files');}}\""
  },
  "dependencies": {
    "@heroui/react": "^2",
    "@heroui/theme": "^2.4.26",
    "framer-motion": "^11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7",
    "zustand": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^25",
    "tailwindcss": "^4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3"
  }
}
